\b \u1054\u1058\u1063\u1045\u1058. \u1047\u1072\u1076\u1072\u1085\u1080\u1077 1. \u1058\u1072\u1073\u1083\u1080\u1095\u1085\u1072\u1103 \u1092\u1091\u1085\u1082\u1094\u1080\u1103\b0\par
\u1057\u1090\u1091\u1076\u1077\u1085\u1090\u1099 \u1089\u1086 \u1089\u1088\u1077\u1076\u1085\u1080\u1084 \u1073\u1072\u1083\u1083\u1086\u1084 \u1074\u1099\u1096\u1077 \u1079\u1072\u1076\u1072\u1085\u1085\u1086\u1075\u1086\par
\par

\b \u1063\u1058\u1054 \u1044\u1045\u1051\u1040\u1045\u1058 \u1057\u1050\u1056\u1048\u1055\u1058:\b0\par
1. \u1057\u1086\u1079\u1076\u1072\u1105\u1090 \u1090\u1072\u1073\u1083\u1080\u1094\u1099 students \u1080 grades (\u1077\u1089\u1083\u1080 \u1080\u1093 \u1077\u1097\u1105 \u1085\u1077\u1090).\par
2. \u1047\u1072\u1087\u1086\u1083\u1085\u1103\u1077\u1090 \u1080\u1093 \u1087\u1088\u1080\u1084\u1077\u1088\u1072\u1084\u1080 \u1076\u1072\u1085\u1085\u1099\u1093 (\u1089\u1090\u1091\u1076\u1077\u1085\u1090\u1099 \u1080 \u1086\u1094\u1077\u1085\u1082\u1080 \u1087\u1086 \u1087\u1088\u1077\u1076\u1084\u1077\u1090\u1072\u1084).\par
3. \u1057\u1086\u1079\u1076\u1072\u1105\u1090 \u1090\u1072\u1073\u1083\u1080\u1095\u1085\u1091\u1102 \u1092\u1091\u1085\u1082\u1094\u1080\u1102 get_students_above_avg(...).\par
\par

\b \u1058\u1040\u1041\u1051\u1048\u1062\u1067:\b0\par
\u2022 students \u2014 \u1089\u1090\u1091\u1076\u1077\u1085\u1090\u1099: id, full_name.\par
\u2022 grades \u2014 \u1086\u1094\u1077\u1085\u1082\u1080: id, student_id (\u1089\u1089\u1099\u1083\u1082\u1072 \u1085\u1072 students), subject, grade.\par
\par

\b \u1063\u1058\u1054 \u1044\u1045\u1051\u1040\u1045\u1058 \u1060\u1059\u1053\u1050\u1062\u1048\u1071 get_students_above_avg(min_avg_grade):\b0\par
\u2022 \u1055\u1088\u1080\u1085\u1080\u1084\u1072\u1077\u1090 \u1086\u1076\u1080\u1085 \u1072\u1088\u1075\u1091\u1084\u1077\u1085\u1090: \u1084\u1080\u1085\u1080\u1084\u1072\u1083\u1100\u1085\u1099\u1081 \u1089\u1088\u1077\u1076\u1085\u1080\u1081 \u1073\u1072\u1083\u1083 (\u1090\u1080\u1087 NUMERIC).\par
\u2022 \u1044\u1083\u1103 \u1082\u1072\u1078\u1076\u1086\u1075\u1086 \u1089\u1090\u1091\u1076\u1077\u1085\u1090\u1072 \u1089\u1095\u1080\u1090\u1072\u1077\u1090 \u1089\u1088\u1077\u1076\u1085\u1080\u1081 \u1073\u1072\u1083\u1083 \u1087\u1086 \u1074\u1089\u1077\u1084 \u1077\u1075\u1086 \u1086\u1094\u1077\u1085\u1082\u1072\u1084 \u1080\u1079 grades.\par
\u2022 \u1054\u1089\u1090\u1072\u1074\u1083\u1103\u1077\u1090 \u1090\u1086\u1083\u1100\u1082\u1086 \u1090\u1077\u1093, \u1091 \u1082\u1086\u1075\u1086 \u1089\u1088\u1077\u1076\u1085\u1080\u1081 \u1073\u1072\u1083\u1083 \u1057\u1058\u1056\u1054\u1043\u1054 \u1041\u1054\u1051\u1068\u1064\u1045 \u1079\u1072\u1076\u1072\u1085\u1085\u1086\u1075\u1086 \u1087\u1086\u1088\u1086\u1075\u1072.\par
\u2022 \u1042\u1086\u1079\u1074\u1088\u1072\u1097\u1072\u1077\u1090 \u1090\u1072\u1073\u1083\u1080\u1094\u1091 \u1089 \u1082\u1086\u1083\u1086\u1085\u1082\u1072\u1084\u1080: student_id, full_name, avg_grade.\par
\par

\b \u1050\u1040\u1050 \u1056\u1040\u1041\u1054\u1058\u1040\u1045\u1058 \u1042\u1053\u1059\u1058\u1056\u1048:\b0\par
\u2022 JOIN \u1089\u1074\u1103\u1079\u1099\u1074\u1072\u1077\u1090 \u1089\u1090\u1091\u1076\u1077\u1085\u1090\u1086\u1074 \u1089 \u1080\u1093 \u1086\u1094\u1077\u1085\u1082\u1072\u1084\u1080.\par
\u2022 GROUP BY s.id, s.full_name \u2014 \u1075\u1088\u1091\u1087\u1087\u1080\u1088\u1086\u1074\u1082\u1072 \u1087\u1086 \u1089\u1090\u1091\u1076\u1077\u1085\u1090\u1091.\par
\u2022 AVG(g.grade) \u2014 \u1089\u1088\u1077\u1076\u1085\u1080\u1081 \u1073\u1072\u1083\u1083 \u1087\u1086 \u1087\u1088\u1077\u1076\u1084\u1077\u1090\u1072\u1084.\par
\u2022 HAVING AVG(g.grade) > min_avg_grade \u2014 \u1092\u1080\u1083\u1100\u1090\u1088 \u00AB\u1074\u1099\u1096\u1077 \u1079\u1072\u1076\u1072\u1085\u1085\u1086\u1075\u1086\u00BB.\par
\u2022 ROUND(..., 2) \u2014 \u1089\u1088\u1077\u1076\u1085\u1080\u1081 \u1086\u1082\u1088\u1091\u1075\u1083\u1103\u1077\u1090\u1089\u1103 \u1076\u1086 \u1076\u1074\u1091\u1093 \u1079\u1085\u1072\u1082\u1086\u1074 \u1087\u1086\u1089\u1083\u1077 \u1079\u1072\u1087\u1103\u1090\u1086\u1081.\par
\par

